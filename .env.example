# Personal Finance MCP — environment variables (all optional)
# Copy to .env if you want to override defaults. No secrets are required.

# Unified web/MCP server (python -m src.web)
PORT=7860

# Legacy SSE server (run_production.py)
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Frontend: only needed if the website is hosted separately from the API.
# Leave unset when the unified server serves both (same origin).
# NEXT_PUBLIC_API_BASE=https://your-host.example.com
